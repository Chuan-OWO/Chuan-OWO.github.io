* {
  padding: 0;
  margin: 0;
  box-sizing: border-box;
}

body {
  font-family: Arial, Helvetica, sans-serif;
}

.navbar {
  width: 100%;
  min-height: 10vh;
  display: flex;
  background: rgb(115, 149, 111);
}
.navbar a {
  color: white;
  text-align: center;
  text-decoration: none;
  font-size: 2rem;
  padding: 1rem;
}
.navbar a:hover {
  background-color: #ddd;
  color: black;
}

main {
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  text-align: center;
  background: rgb(115, 149, 111);
  color: white;
}
main h1 {
  margin-bottom: 1rem;
  font-size: 3rem;
}
main a {
  margin-bottom: 1rem;
}

.icon {
  display: flex;
  text-align: center;
  justify-content: center;
}
.icon a {
  font-size: 2rem;
  margin: 1rem;
  color: white;
}
.icon a:hover {
  color: black;
}

.banner {
  width: 100%;
  height: 100vh;
  background-color: #ccc;
  background: linear-gradient(115deg, rgb(115, 149, 111) 50%, transparent 50%) center center/100% 100%, #ccc right center/auto 100%;
}

.container {
  width: 100%;
  max-width: 1200px;
  height: 100%;
  margin: auto;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
}

.banner-txt-left {
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: flex-start;
}
.banner-txt-left h1 {
  font-size: 3em;
  /* border-bottom: 1px solid #333; */
  font-weight: 900;
  padding-bottom: 0.3em;
  margin-bottom: 0.3em;
  color: white;
}

.banner-txt-right {
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: flex-start;
  color: rgb(115, 149, 111);
}
.banner-txt-right h1 {
  font-size: 3em;
  font-weight: 900;
  padding-bottom: 0.3em;
  margin-bottom: 0.3em;
}
.banner-txt-right h1 small {
  display: block;
  font-size: 0.5em;
  font-weight: 700;
}

footer {
  width: 100%;
  max-height: auto;
  background: rgb(115, 149, 111);
  color: white;
}
footer .icon {
  display: flex;
  text-align: center;
  justify-content: center;
  padding: 1em;
}
footer .icon a {
  font-size: 2rem;
  margin: 1rem;
}
footer .icon a:hover {
  color: black;
}
footer h5 {
  text-align: center;
  padding-bottom: 2em;
}

